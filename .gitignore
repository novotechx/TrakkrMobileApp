# ─── Gradle ──────────────────────────────────────────────────
.gradle/
build/
**/build/
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

# ─── Kotlin / KMP ────────────────────────────────────────────
.kotlin/
kotlin-js-store/
*.klib

# Kotlin/Native build cache
.konan/

# ─── Android ─────────────────────────────────────────────────
# Build outputs
*.apk
*.aab
*.ap_
*.dex
*.class
bin/
gen/
out/
release/
captures/
.navigation/
.externalNativeBuild/
.cxx/

# Profiling / benchmarking
*.hprof
profile.bin
app.prof

# Android Studio NDK side-by-side versions
/.ndk/

# Lint cache (results themselves are fine to commit)
lint/intermediates/
lint/generated/
lint/outputs/
lint/tmp/

# ─── iOS / Xcode ─────────────────────────────────────────────
iosApp/Pods/
iosApp/.symlinks/
iosApp/iosApp.xcworkspace/xcuserdata/
iosApp/iosApp.xcodeproj/xcuserdata/
iosApp/iosApp.xcodeproj/project.xcworkspace/xcuserdata/
*.xcuserstate
*.xcscmblueprint
DerivedData/
xcuserdata/
*.hmap

# CocoaPods lockfile is usually committed; remove this line if you don't vendor Pods
# Podfile.lock

# ─── Secrets & local configuration ───────────────────────────
local.properties
*.jks
*.keystore
*.p12
*.p8
*.mobileprovision
google-services.json
GoogleService-Info.plist

# ─── IDE: IntelliJ / Android Studio ──────────────────────────
# Ignore everything in .idea except shared, team-wide settings.
# Note: we use `.idea/*` (not `**`) so git can still descend into the
# un-ignored directories below.
.idea/*
!.idea/codeStyles/
!.idea/inspectionProfiles/
!.idea/runConfigurations/
!.idea/copyright/
!.idea/vcs.xml

*.iml
*.iws
*.ipr

# ─── IDE: VS Code ────────────────────────────────────────────
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ─── IDE: Fleet ──────────────────────────────────────────────
.fleet/

# ─── OS cruft ────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# ─── Misc ────────────────────────────────────────────────────
*.log
*.tmp
*.swp
*.swo
*.bak
*.orig
